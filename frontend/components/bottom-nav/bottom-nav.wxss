.bottom-nav-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  padding: 8rpx 8rpx calc(env(safe-area-inset-bottom) + 8rpx);
  pointer-events: none;
}

.bottom-nav {
  pointer-events: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 24rpx;
  border: 1px solid var(--glass-border-medium);
  background: color-mix(in srgb, var(--glass-surface-strong) 92%, white 8%);
  box-shadow: var(--glass-shadow-ambient);
  min-height: 82rpx;
  padding: 6rpx 8rpx 18rpx;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 8rpx 0;
  border-radius: 16rpx;
}

.nav-item .icon {
  font-size: 24rpx;
  line-height: 1;
  opacity: 0.7;
}

.nav-item .label {
  font-size: 20rpx;
  line-height: 1;
  color: var(--muted-foreground);
}

.nav-item.active {
  background: color-mix(in srgb, var(--primary) 16%, transparent);
}

.nav-item.active .icon,
.nav-item.active .label {
  opacity: 1;
  color: var(--primary);
  font-weight: 700;
}
