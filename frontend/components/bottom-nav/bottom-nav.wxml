<view class="bottom-nav-wrap">
  <view class="bottom-nav glass-panel glass-blur-md">
    <view class="nav-item {{current === 'home' ? 'active' : ''}}" data-target="home" bindtap="onNavTap">
      <text class="icon">🏠</text>
      <text class="label">首页</text>
    </view>
    <view class="nav-item {{current === 'spin' ? 'active' : ''}}" data-target="spin" bindtap="onNavTap">
      <text class="icon">🎡</text>
      <text class="label">转盘</text>
    </view>
    <view class="nav-item {{current === 'swipe' ? 'active' : ''}}" data-target="swipe" bindtap="onNavTap">
      <text class="icon">💘</text>
      <text class="label">滑选</text>
    </view>
    <view class="nav-item {{current === 'restaurants' ? 'active' : ''}}" data-target="restaurants" bindtap="onNavTap">
      <text class="icon">🍽️</text>
      <text class="label">食堂</text>
    </view>
    <view class="nav-item {{current === 'mine' ? 'active' : ''}}" data-target="mine" bindtap="onNavTap">
      <text class="icon">👤</text>
      <text class="label">我的</text>
    </view>
  </view>
</view>