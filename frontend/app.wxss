/**app.wxss**/
page {
  --primary: #ff5a3d;
  --primary-foreground: #fff8f2;
  --accent: #ffb547;
  --accent-foreground: #3a2100;
  --success: #28c76f;
  --success-foreground: #052512;
  --warning: #ff8a00;
  --warning-foreground: #3d2100;
  --danger: #ef4444;
  --danger-foreground: #3a0a0a;

  --background: #fff6ec;
  --foreground: #3b2617;
  --card: rgba(255, 255, 255, 0.76);
  --card-foreground: #3b2617;
  
  --glass-surface-extra-transparent: rgba(255, 255, 255, 0.18);
  --glass-surface-light: rgba(255, 255, 255, 0.28);
  --glass-surface-medium: rgba(255, 255, 255, 0.38);
  --glass-surface-strong: rgba(255, 255, 255, 0.52);

  --glass-text-strong: #3f2918;
  --glass-text-default: #482e1b;
  --glass-text-muted: #664327;
  --glass-text-muted-transparent: rgba(59, 38, 23, 0.58);
  --glass-text-inverse: #ffffff;

  --glass-border-soft: rgba(255, 255, 255, 0.26);
  --glass-border-medium: rgba(255, 255, 255, 0.44);
  --glass-border-strong: rgba(255, 255, 255, 0.62);

  --glass-shadow-ambient: 0 14px 40px rgba(141, 78, 30, 0.2);
  --glass-shadow-glow: 0 0 0 1px rgba(255, 154, 92, 0.28), 0 22px 52px rgba(255, 128, 54, 0.3);
  --neumorph-shadow-soft: 10px 10px 24px rgba(199, 150, 109, 0.26), -10px -10px 24px rgba(255, 255, 255, 0.72);
  --neumorph-shadow-strong: 14px 14px 30px rgba(188, 133, 89, 0.32), -14px -14px 30px rgba(255, 255, 255, 0.85);
  --topbar-bg: rgba(255, 255, 255, 0.46);
  --topbar-border-color: var(--glass-border-strong);

  --glass-blur-sm: 8px;
  --glass-blur-md: 14px;
  --glass-blur-lg: 22px;
  
  --muted-foreground: #846651;
  --color-success: #28c76f;
  
  background-color: var(--background);
  color: var(--foreground);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.app-shell {
  width: 100%;
  max-width: 780rpx;
  min-height: 100vh;
  margin: 0 auto;
  position: relative;
  background: var(--background);
}

.page-with-bottom-nav {
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.glass-panel {
  background: var(--glass-surface-medium);
  border: 1px solid var(--glass-border-medium);
  box-shadow: var(--glass-shadow-ambient);
  backdrop-filter: blur(var(--glass-blur-sm));
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
}

.glass-overlay {
  background: var(--glass-surface-strong);
  border: 1px solid var(--glass-border-strong);
  box-shadow: var(--glass-shadow-glow);
  backdrop-filter: blur(var(--glass-blur-sm));
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
}

.glass-chip {
  background: var(--glass-surface-light);
  border: 1px solid var(--glass-border-soft);
  backdrop-filter: blur(var(--glass-blur-sm));
  -webkit-backdrop-filter: blur(var(--glass-blur-sm));
}

.glass-nav {
  background: rgba(255, 255, 255, 0.46);
  border: 1px solid var(--glass-border-strong);
  box-shadow: var(--glass-shadow-ambient);
  backdrop-filter: blur(var(--glass-blur-md));
  -webkit-backdrop-filter: blur(var(--glass-blur-md));
}

.enhanced-neumorph-card {
  box-shadow: var(--neumorph-shadow-soft);
}

.enhanced-neumorph-card.neumorph-strong {
  box-shadow: var(--neumorph-shadow-strong);
}

.unified-topbar {
  background: var(--topbar-bg);
  border-color: var(--topbar-border-color);
}

.page-topbar {
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.page-topbar-row {
  min-height: 88rpx;
  padding-top: calc(env(safe-area-inset-top) + 8rpx);
  display: flex;
  align-items: center;
}

.topbar-back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-surface-light);
  border: 1px solid var(--glass-border-medium);
  margin-right: 16rpx;
}

.topbar-title {
  color: var(--primary-foreground);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.1;
}

.topbar-subtitle {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: color-mix(in srgb, var(--primary-foreground) 78%, transparent);
}

.topbar-spacer {
  width: 56rpx;
  height: 56rpx;
  margin-left: auto;
}

.click-hover-lift {
  transition: transform 0.2s, box-shadow 0.2s;
}

.click-hover-lift:active {
  transform: translateY(0) scale(0.97);
  box-shadow: var(--glass-shadow-ambient);
}

.px-2_5 { padding-left: 20rpx; padding-right: 20rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.px-5 { padding-left: 40rpx; padding-right: 40rpx; }
.py-0_5 { padding-top: 4rpx; padding-bottom: 4rpx; }
.py-1_5 { padding-top: 12rpx; padding-bottom: 12rpx; }
.py-2_5 { padding-top: 20rpx; padding-bottom: 20rpx; }
.py-3_5 { padding-top: 28rpx; padding-bottom: 28rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.pb-5 { padding-bottom: 40rpx; }
.pb-6 { padding-bottom: 48rpx; }
.pt-4 { padding-top: 32rpx; }
.mt-0_5 { margin-top: 4rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }
.-mt-2 { margin-top: -16rpx; }

.ml-auto { margin-left: auto; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-0_5 { gap: 4rpx; }
.gap-1 { gap: 8rpx; }
.gap-1_5 { gap: 12rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.shrink-0 { flex-shrink: 0; }
.min-w-0 { min-width: 0; }

.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.overflow-hidden { overflow: hidden; }

.w-full { width: 100%; }
.min-h-full { min-height: 100%; }

.text-center { text-align: center; }
.text-left { text-align: left; }

.rounded-xl { border-radius: 24rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-2xl { border-radius: 32rpx; }
.rounded-3xl { border-radius: 48rpx; }
.rounded-full { border-radius: 9999rpx; }

.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.leading-tight { line-height: 1.25; }

.text-foreground { color: var(--foreground); }
.text-muted-foreground { color: var(--muted-foreground); }

.object-cover { object-fit: cover; }
