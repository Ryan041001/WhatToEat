.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 180, 0.65), transparent 30%),
    linear-gradient(180deg, #fffaf6 0%, #fff4ec 100%);
}

.chat-header {
  padding: 28rpx 28rpx 18rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6b7280;
}

.chat-scroll {
  flex: 1;
  min-height: 0;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 8rpx 28rpx 28rpx;
}

.profile-hint {
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #ecfeff;
  border: 1px solid #c4f1f9;
  color: #0f766e;
  font-size: 22rpx;
}

.empty-state {
  margin-top: 40rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1px solid rgba(255, 228, 211, 0.9);
  box-shadow: 0 12rpx 30rpx rgba(255, 107, 107, 0.08);
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.empty-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #6b7280;
}

.message-row {
  display: flex;
}

.message-row-user {
  justify-content: flex-end;
}

.message-row-assistant {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 90%;
  padding: 20rpx 22rpx;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.bubble-user {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff9e2a 100%);
  color: #ffffff;
  border-bottom-right-radius: 12rpx;
}

.bubble-assistant {
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(255, 228, 211, 0.92);
  border-bottom-left-radius: 12rpx;
}

.message-name {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #ff6b6b;
}

.user-text {
  display: block;
  font-size: 27rpx;
  line-height: 1.7;
  color: inherit;
  word-break: break-word;
}

.assistant-rich-text {
  display: block;
}

.assistant-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
  word-break: break-word;
}

.assistant-text-draft {
  color: #4b5563;
}

.typing-indicator {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0 2rpx;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.55);
  animation: typing-pulse 1.1s ease-in-out infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.12s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.24s;
}

.stream-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #98a2b3;
}

.assistant-card-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.assistant-card {
  display: flex;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-sizing: border-box;
  background: rgba(255, 247, 242, 0.98);
  border: 1px solid rgba(255, 218, 193, 0.95);
}

.card-enter {
  opacity: 0;
  transform: translateY(18rpx) scale(0.98);
  animation: card-pop-in 0.34s ease forwards;
}

.card-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.card-rank {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
  font-size: 18rpx;
  font-weight: 700;
}

.card-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #374151;
}

.card-rating {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 158, 42, 0.12);
}

.star-shell {
  width: 22rpx;
  height: 22rpx;
  display: block;
  color: #ff9e2a;
}

.rating-value {
  font-size: 20rpx;
  color: #ff9e2a;
  font-weight: 700;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-chip {
  font-size: 18rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.meta-item {
  font-size: 18rpx;
  color: #667085;
}

.meta-dot {
  font-size: 18rpx;
  color: #d0d5dd;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(255, 158, 42, 0.12);
  color: #c56a12;
  font-size: 16rpx;
}

.card-desc {
  font-size: 18rpx;
  line-height: 1.55;
  color: #8b93a6;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: stretch;
  gap: 10rpx;
  margin-top: auto;
  width: 100%;
}

.action-btn {
  flex: 1 1 0;
  min-width: 0;
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: none;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 17rpx;
  font-weight: 600;
  white-space: nowrap;
}

.action-btn::after {
  border: none;
}

.btn-pick {
  background: rgba(34, 197, 94, 0.12);
  color: #15803d;
}

.btn-detail {
  background: rgba(255, 158, 42, 0.14);
  color: #c56a12;
}

.btn-reject {
  background: rgba(255, 107, 107, 0.12);
  color: #ff6b6b;
}

.composer {
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.95);
  backdrop-filter: blur(12px);
  border-top: 1px solid rgba(255, 228, 211, 0.92);
}

.composer-shell {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  padding: 10rpx 10rpx 10rpx 14rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.composer-input-wrap {
  position: relative;
  flex: 1;
  min-width: 0;
}

.composer-input {
  width: 100%;
  min-height: 64rpx;
  max-height: 220rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
  position: relative;
  z-index: 2;
  background: transparent;
}

.composer-preset {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  padding-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #98a2b3;
  z-index: 1;
  pointer-events: none;
}

.send-btn {
  flex: 0 0 68rpx;
  width: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  height: 68rpx;
  padding: 0;
  border-radius: 50%;
  flex-shrink: 0;
  align-self: flex-end;
  box-sizing: border-box;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff9e2a 100%);
  box-shadow: 0 10rpx 20rpx rgba(255, 107, 107, 0.2);
}

.send-btn-loading {
  opacity: 0.92;
}

.send-icon-shell {
  width: 28rpx;
  height: 28rpx;
  display: block;
  color: #ffffff;
}

.send-icon-loading {
  width: 30rpx;
  height: 30rpx;
}

@keyframes typing-pulse {
  0%, 80%, 100% {
    opacity: 0.35;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-3rpx);
  }
}

@keyframes card-pop-in {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
