.page {
  min-height: 100vh;
  padding: 28rpx;
  background: #fff7f2;
}

.header {
  margin-bottom: 20rpx;
}

.profile-hint {
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #ecfeff;
  border: 1px solid #c4f1f9;
  color: #0f766e;
  font-size: 22rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.panel {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1px solid #ffe4d3;
}

.question-input {
  width: 100%;
  min-height: 132rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
}

.action-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.btn {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  border: none;
  padding: 0 24rpx;
}

.btn::after {
  border: none;
}

.btn.primary {
  flex: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff9e2a 100%);
  box-shadow: 0 10rpx 20rpx rgba(255, 107, 107, 0.22);
}

.btn.ghost {
  min-width: 188rpx;
  color: #ff6b6b;
  background: #fff1ec;
  border: 1px solid #ffd0be;
}

.status {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 10rpx;
}

.answer-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: #374151;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #fff9f6;
  border: 1px solid #ffd9c2;
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.card-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
}

.card-distance {
  font-size: 22rpx;
  color: #6b7280;
}

.card-meta {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 22rpx;
  color: #4b5563;
}

.tag-row {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #b45309;
  background: #ffedd5;
}

.reason {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #374151;
}

.card-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.mini-btn {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #ff6b6b;
  background: #fff;
  border: 1px solid #ffc5ab;
}

.mini-btn.warn {
  color: #b42318;
  border-color: #fdb7b2;
  background: #fff1f1;
}

.mini-btn.success {
  color: #166534;
  border-color: #bbf7d0;
  background: #f0fdf4;
}

.mini-btn::after {
  border: none;
}
