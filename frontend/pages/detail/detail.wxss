/* pages/detail/detail.wxss */

.page {
  min-height: 100vh;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.detail-hero {
  margin-bottom: 20rpx;
}

.hero-blob-one {
  top: -44rpx;
  right: -34rpx;
  width: 220rpx;
  height: 220rpx;
}

.hero-blob-two {
  bottom: -78rpx;
  left: 120rpx;
  width: 176rpx;
  height: 176rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.hero-eyebrow {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.hero-chip {
  flex-shrink: 0;
}

.hero-chip-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.28;
  color: #FFFFFF;
}

.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.hero-meta {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.22);
}

.hero-meta-star {
  background: rgba(255, 255, 255, 0.22);
}

.meta-icon-shell {
  width: 24rpx;
  height: 24rpx;
  color: #FFFFFF;
}

.meta-icon-star {
  color: #FFE3A3;
}

.hero-meta-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.detail-body {
  position: relative;
  z-index: 2;
  margin-top: -28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cover-card {
  padding: 18rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 32rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.1);
}

.info-card {
  padding: 28rpx;
}

.section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.info-block + .info-block {
  margin-top: 24rpx;
}

.info-title {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.info-text {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.7;
}

.tags {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.btn::after {
  border: none;
}

.btn.ghost {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(255, 107, 107, 0.18);
  color: #FF6B6B;
}

.btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  color: #FFFFFF;
  box-shadow: 0 18rpx 36rpx rgba(255, 107, 107, 0.2);
}

.error {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  color: #B42318;
  font-size: 24rpx;
}
