.summary-card {
  padding: 24rpx;
}

.summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-tip {
  font-size: 22rpx;
  color: #98A2B3;
}

.summary-metrics {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-metric-item {
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.58);
}

.summary-metric-label {
  display: block;
  color: #98A2B3;
  font-size: 20rpx;
}

.summary-metric-value {
  display: block;
  margin-top: 6rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
}

.mini-stars {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.mini-star-shell {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}

.mini-star-track,
.mini-star-fill {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.mini-star-track {
  color: rgba(255, 158, 42, 0.2);
}

.mini-star-face,
.rating-star-face {
  width: 100%;
  height: 100%;
}

.mini-star-face-empty,
.rating-star-face-empty {
  background: none;
}

.mini-star-face-half,
.rating-star-face-half {
  background: linear-gradient(90deg, #FF9E2A 0%, #FF9E2A 50%, transparent 50%, transparent 100%);
}

.mini-star-face-full,
.rating-star-face-full {
  background: #FF9E2A;
}

.summary-text-wrap {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.58);
}

.summary-text {
  color: #344054;
  font-size: 24rpx;
  line-height: 1.6;
}

.summary-empty {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  color: #98A2B3;
  font-size: 22rpx;
}

.scenario-wrap {
  margin-top: 14rpx;
}

.scenario-title {
  display: block;
  color: #667085;
  font-size: 22rpx;
  font-weight: 600;
}

.scenario-tags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.scenario-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 158, 42, 0.16);
  color: #B54708;
  font-size: 20rpx;
}

.rating-field,
.price-field {
  margin-bottom: 14rpx;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.field-label {
  color: #667085;
  font-size: 22rpx;
}

.field-value {
  font-size: 22rpx;
  color: #98A2B3;
  font-weight: 600;
}

.field-value.active {
  color: #FF6B6B;
}

.rating-stars {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.rating-star-shell {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.rating-star-track,
.rating-star-fill {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.rating-star-track {
  color: rgba(255, 158, 42, 0.2);
}

.rating-slider {
  margin-top: 8rpx;
}

.rating-scale {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
  color: #98A2B3;
  font-size: 20rpx;
}

.price-input {
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  color: #344054;
}

.comment-actions {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  border-radius: 999rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #B42318;
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(180, 35, 24, 0.16);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
}

.comment-delete::after {
  border: none;
}

.comment-extra {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.comment-extra-item {
  color: #667085;
  font-size: 20rpx;
}

.comment-rating-inline {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}
/* pages/detail/detail.wxss */

.page {
  min-height: 100vh;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.detail-hero {
  margin-bottom: 20rpx;
}

.hero-blob-one {
  top: -44rpx;
  right: -34rpx;
  width: 220rpx;
  height: 220rpx;
}

.hero-blob-two {
  bottom: -78rpx;
  left: 120rpx;
  width: 176rpx;
  height: 176rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.hero-eyebrow {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.hero-chip {
  flex-shrink: 0;
}

.hero-chip-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.28;
  color: #FFFFFF;
}

.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.hero-meta {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.22);
}

.hero-meta-star {
  background: rgba(255, 255, 255, 0.22);
}

.meta-icon-shell {
  width: 24rpx;
  height: 24rpx;
  color: #FFFFFF;
}

.meta-icon-star {
  color: #FFE3A3;
}

.hero-meta-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.detail-body {
  position: relative;
  z-index: 2;
  margin-top: -28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cover-card {
  padding: 18rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 32rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.1);
}

.info-card {
  padding: 28rpx;
}

.section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.info-block + .info-block {
  margin-top: 24rpx;
}

.info-title {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.info-text {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.7;
}

.tags {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.comment-card {
  padding: 24rpx;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.comment-count {
  font-size: 22rpx;
  color: #98A2B3;
}

.comment-editor {
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(255, 107, 107, 0.1);
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.6;
}

.comment-submit {
  flex: 1;
  border-radius: 999rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 26rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 107, 0.22);
}

.comment-submit[disabled] {
  color: #FFFFFF;
  opacity: 0.58;
}

.comment-submit::after {
  border: none;
}

.comment-empty {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.45);
  color: #98A2B3;
  font-size: 24rpx;
  text-align: center;
}

.comment-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.comment-item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.56);
}

.comment-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.comment-author {
  color: #475467;
  font-size: 24rpx;
  font-weight: 700;
}

.comment-time {
  color: #98A2B3;
  font-size: 20rpx;
}

.comment-content {
  display: block;
  margin-top: 8rpx;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.6;
}

.actions {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.btn::after {
  border: none;
}

.btn.ghost {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(255, 107, 107, 0.18);
  color: #FF6B6B;
}

.btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  color: #FFFFFF;
  box-shadow: 0 18rpx 36rpx rgba(255, 107, 107, 0.2);
}

.error {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  color: #B42318;
  font-size: 24rpx;
}
