<view class="home-container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索餐厅..." bindinput="onSearchInput" />
  </view>
  
  <scroll-view class="restaurant-list" scroll-y bindscrolltolower="onLoadMore">
    <loading-spinner show="{{isLoading && restaurants.length === 0}}" message="加载数据中..."></loading-spinner>
    
    <block wx:for="{{restaurants}}" wx:key="id">
      <restaurant-card restaurant="{{item}}" bind:tapcard="goToDetail"></restaurant-card>
    </block>

    <view class="loading-more" wx:if="{{isLoading && restaurants.length > 0}}">
      <loading-spinner show="{{true}}" message="加载更多..."></loading-spinner>
    </view>
    
    <view class="no-more" wx:if="{{!hasMore && restaurants.length > 0}}">没有更多餐馆了</view>
    
    <view class="empty-state" wx:if="{{!isLoading && restaurants.length === 0}}">
      <text class="empty-icon">😢</text>
      <text>暂无找到相关餐馆</text>
    </view>
  </scroll-view>
</view>
