/* pages/home/home.wxss */

.error-banner {
  margin: 24rpx 32rpx 0;
  background: #fff0ef;
  color: #b42318;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

/* Header */
.header {
  position: relative;
  padding: 32rpx 40rpx 48rpx;
  background: #F97316;
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.blob-1 {
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
}

.blob-2 {
  bottom: -60rpx;
  left: 120rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.header-title {
  display: block;
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.header-badge {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.2);
}

.badge-text {
  color: #fff;
  font-size: 22rpx;
}

.mine-entry {
  padding: 8rpx 22rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.26);
  border: 1px solid rgba(255, 255, 255, 0.35);
}

.mine-entry-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.today-pick {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.pick-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pick-emoji {
  font-size: 48rpx;
}

.pick-text {
  display: flex;
  flex-direction: column;
}

.pick-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.pick-subtitle {
  color: rgba(255, 255, 255, 0.75);
  font-size: 22rpx;
}

.pick-btn {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  background: #fff;
}

.pick-btn-text {
  color: #F97316;
  font-size: 24rpx;
  font-weight: 700;
}

/* Quick actions */
.quick-actions {
  margin-bottom: 48rpx;
}

.actions-card {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  border-radius: 48rpx;
  border: 1px solid transparent;
}

.action-spin {
  background: #6C82E8;
  border-color: #5B70D6;
}

.action-shake {
  background: #E98A3F;
  border-color: #D8782E;
}

.action-swipe {
  background: #6FA58C;
  border-color: #5C947B;
}

.action-emoji {
  font-size: 56rpx;
}

.action-emoji.shaking {
  animation: shake 0.8s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  10%, 30%, 50%, 70%, 90% { transform: rotate(-15deg) scale(1.1); }
  20%, 40%, 60%, 80% { transform: rotate(15deg) scale(1.1); }
}

.action-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* Shake result */
.shake-result {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.shake-result.show {
  opacity: 1;
  pointer-events: all;
}

.shake-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx;
  background: #F97316;
  border-radius: 60rpx;
  box-shadow: 0 40rpx 120rpx rgba(249, 115, 22, 0.5);
  max-width: 560rpx;
}

.shake-emoji {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.shake-label {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.shake-name {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.shake-tip {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

/* Stats row */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-emoji {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C5C5C;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

/* Hot picks */
.hot-picks {
  margin-bottom: 48rpx;
}

.picks-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.picks-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  width: 28rpx;
  height: 28rpx;
}

.picks-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #5C5C5C;
}

.picks-more {
  font-size: 24rpx;
  color: #F97316;
}

.picks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pick-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.pick-image-wrapper {
  position: relative;
  flex-shrink: 0;
}

.pick-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
}

.pick-rank {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
}

.rank-0 {
  background: #F97316;
}

.rank-1 {
  background: #84A98C;
}

.rank-2 {
  background: #a0a0a0;
}

.pick-info {
  flex: 1;
  min-width: 0;
}

.pick-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.pick-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  font-size: 20rpx;
}

.rating-value {
  font-size: 22rpx;
  color: #F97316;
  font-weight: 600;
}

.distance {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.distance-icon {
  font-size: 18rpx;
}

.distance-text {
  font-size: 20rpx;
  color: #999;
}

.price {
  font-size: 20rpx;
  color: #999;
}

.pick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.pick-tags .tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  background: #FFF0ED;
  color: #F97316;
  border-radius: 8rpx;
}

/* Add button */
.add-btn-wrapper {
  margin-bottom: 48rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  background: transparent;
  border: 4rpx dashed #F97316;
  border-radius: 48rpx;
  color: #F97316;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 600;
}

.add-text {
  font-size: 26rpx;
  font-weight: 600;
}
