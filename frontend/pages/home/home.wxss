.text-10 { font-size: 20rpx; }
.text-11 { font-size: 22rpx; }
.text-12 { font-size: 24rpx; }
.text-13 { font-size: 26rpx; }
.text-14 { font-size: 28rpx; }
.text-16 { font-size: 32rpx; }
.text-18 { font-size: 36rpx; }
.text-22 { font-size: 44rpx; }
.text-24 { font-size: 48rpx; }
.text-28 { font-size: 56rpx; }
.text-48 { font-size: 96rpx; }

.h-14 { height: 112rpx; }
.w-14 { width: 112rpx; }
.h-20 { height: 160rpx; }
.w-20 { width: 160rpx; }
.h-24 { height: 192rpx; }
.w-24 { width: 192rpx; }

.-top-1 { top: -2rpx; }
.-left-1 { left: -2rpx; }
.-top-5 { top: -40rpx; }
.-right-5 { right: -40rpx; }
.-bottom-7 { bottom: -56rpx; }
.left-16 { left: 128rpx; }

.px-1_5 { padding-left: 12rpx; padding-right: 12rpx; }
.py-0_5 { padding-top: 4rpx; padding-bottom: 4rpx; }
.px-3 { padding-left: 24rpx; padding-right: 24rpx; }
.py-1 { padding-top: 8rpx; padding-bottom: 8rpx; }
.py-1_5 { padding-top: 12rpx; padding-bottom: 12rpx; }
.mt-0_5 { margin-top: 4rpx; }
.gap-0_5 { gap: 4rpx; }
