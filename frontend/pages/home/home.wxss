/* pages/home/home.wxss */

.error-banner {
  margin: 24rpx 32rpx 0;
  background: #fff0ef;
  color: #b42318;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

/* Header */
.header {
  position: relative;
  padding: 32rpx 40rpx 48rpx;
  /* 调整主色调为活力美食风橘红 #FF6B6B */
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.2);
  margin-bottom: 32rpx;
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.blob-1 {
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
}

.blob-2 {
  bottom: -60rpx;
  left: 120rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.header-title {
  display: block;
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.header-badge {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.2);
}

.badge-text {
  color: #fff;
  font-size: 22rpx;
}

.mine-entry {
  padding: 8rpx 22rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.26);
  border: 1px solid rgba(255, 255, 255, 0.35);
}

.mine-entry-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.today-pick {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.pick-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pick-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.5);
}

.pick-text {
  display: flex;
  flex-direction: column;
}

.pick-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.pick-subtitle {
  color: rgba(255, 255, 255, 0.75);
  font-size: 22rpx;
}

.pick-btn {
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.pick-btn-text {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 700;
}

/* Quick actions */
.quick-actions {
  margin: 0 48rpx 48rpx 48rpx;
}

.actions-card {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  /* 应用玻璃拟态 */
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.08);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 16rpx;
  border-radius: 48rpx;
  /* 更精细的玻璃质感边框和投影 */
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
}

.action-spin {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.action-shake {
  background: linear-gradient(135deg, #FF9E2A 0%, #FFC837 100%);
}

.action-swipe {
  background: linear-gradient(135deg, #20C997 0%, #48D1CC 100%);
}

.action-ai {
  background: linear-gradient(135deg, #4F46E5 0%, #06B6D4 100%);
}

.action-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 8rpx;
  color: #fff;
}

.action-icon-shell.shaking {
  animation: shake 0.8s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  10%, 30%, 50%, 70%, 90% { transform: rotate(-15deg) scale(1.1); }
  20%, 40%, 60%, 80% { transform: rotate(15deg) scale(1.1); }
}

.action-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* Shake result */
.shake-result {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.shake-result.show {
  opacity: 1;
  pointer-events: all;
}

.shake-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx;
  background: #F97316;
  border-radius: 60rpx;
  box-shadow: 0 40rpx 120rpx rgba(249, 115, 22, 0.5);
  max-width: 560rpx;
}

.shake-icon-shell {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
  color: #fff;
}

.shake-label {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.shake-name {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}

.shake-card {
  margin-top: 10rpx;
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
  border: 1px solid rgba(255, 255, 255, 0.28);
}

.shake-card-image {
  width: 100%;
  height: 200rpx;
}

.shake-card-body {
  padding: 18rpx 20rpx 20rpx;
}

.shake-card-meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.meta-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  width: 24rpx;
  height: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.shake-card-tip {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
}

.shake-tip {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-top: 14rpx;
}

/* Stats row */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 0 48rpx 48rpx 48rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: 32rpx;
  /* 玻璃拟态 */
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.05);
}

.stat-icon-shell {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.stat-icon-total {
  color: #FF6B6B;
}

.stat-icon-available {
  color: #20C997;
}

.stat-icon-blocked {
  color: #A0A0A0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C5C5C;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

/* Hot picks */
.hot-picks {
  margin: 0 48rpx 48rpx 48rpx;
}

.picks-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.picks-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: #FF6B6B;
}

.picks-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
}

.picks-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #FF6B6B;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 100rpx;
}

.picks-more-text {
  font-size: 24rpx;
  color: inherit;
}

.picks-more-icon {
  width: 24rpx;
  height: 24rpx;
  display: block;
  flex-shrink: 0;
  color: inherit;
}

.picks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pick-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  /* 玻璃拟态 */
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.05);
}

.pick-image-wrapper {
  position: relative;
  flex-shrink: 0;
}

.pick-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
}

.pick-rank {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
}

.rank-0 {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.rank-1 {
  background: linear-gradient(135deg, #FF9E2A, #FFC837);
  box-shadow: 0 4rpx 12rpx rgba(255, 158, 42, 0.4);
}

.rank-2 {
  background: linear-gradient(135deg, #20C997, #48D1CC);
  box-shadow: 0 4rpx 12rpx rgba(32, 201, 151, 0.4);
}

.pick-info {
  flex: 1;
  min-width: 0;
}

.pick-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.pick-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star-icon-shell {
  width: 28rpx;
  height: 28rpx;
  display: block;
  color: #FF9E2A;
}

.rating-value {
  font-size: 22rpx;
  color: #FF9E2A; /* 评分用暖黄更合适 */
  font-weight: 700;
}

.distance {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.distance-icon-shell {
  width: 28rpx;
  height: 28rpx;
  display: block;
  color: #999;
}

.distance-text {
  font-size: 20rpx;
  color: #999;
}

.price {
  font-size: 20rpx;
  color: #999;
}

.pick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.pick-tags .tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 107, 107, 0.08); /* 淡红底色 */
  color: #FF6B6B;
  border-radius: 12rpx;
  font-weight: 500;
}

/* Add button */
.add-btn-wrapper {
  margin: 0 48rpx 48rpx 48rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  /* 玻璃底搭配实线边框，视觉更现代 */
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 107, 107, 0.5);
  border-radius: 48rpx;
  color: #FF6B6B;
}

.add-icon-shell {
  width: 40rpx;
  height: 40rpx;
  display: block;
  color: #FF6B6B;
}

.add-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 底部安全区留白 */
.container {
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}
