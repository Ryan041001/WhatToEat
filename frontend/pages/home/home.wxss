/* pages/home/home.wxss */
.home-header {
  background: linear-gradient(135deg, var(--primary) 0%, #ff9a5c 100%);
}

.decoration-1 {
  background: rgba(255, 255, 255, 0.2);
  filter: blur(4px);
}

.decoration-2 {
  background: rgba(255, 255, 255, 0.15);
  filter: blur(4px);
}

.home-subtitle {
  color: rgba(255, 255, 255, 0.82);
}

.bg-strong {
  background: var(--glass-surface-strong);
  border: 1px solid var(--glass-border-medium);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.btn-spin {
  background: linear-gradient(135deg, var(--primary), #ff8a00);
}

.btn-shake {
  background: linear-gradient(135deg, #ff8a00, var(--primary));
}

.btn-swipe {
  background: linear-gradient(135deg, #ffb547, #28c76f);
}

.btn-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-add {
  border: 1px solid var(--glass-border-medium);
  color: var(--primary);
  background: color-mix(in srgb, var(--warning) 18%, var(--glass-surface-strong));
  box-shadow: var(--glass-shadow-glow);
}

.shake-result-overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.shake-result-overlay.show {
  pointer-events: auto;
  opacity: 1;
}

.shake-content {
  max-width: 560rpx;
  width: 560rpx;
  border-radius: 48rpx;
  padding: 48rpx 64rpx;
  transform: translateY(40rpx) scale(0.8);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.shake-result-overlay.show .shake-content {
  transform: translateY(0) scale(1);
}

.shake-muted {
  color: rgba(255, 255, 255, 0.85);
}

.shake-tip {
  color: rgba(255, 255, 255, 0.7);
}

.stat-card {
  border-radius: 24rpx;
  box-shadow: var(--neumorph-shadow-soft);
}

.anim-shake {
  animation: shake 0.8s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  10%, 30%, 50%, 70%, 90% { transform: rotate(-15deg) scale(1.1); }
  20%, 40%, 60%, 80% { transform: rotate(15deg) scale(1.1); }
}

.anim-fade-in {
  animation: fadeInRight 0.5s both;
}

@keyframes fadeInRight {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.img-shadow {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.rank-badge {
  top: -8rpx;
  left: -8rpx;
  width: 36rpx;
  height: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.rank-bg-0 { background: var(--primary) !important; }
.rank-bg-1 { background: var(--warning) !important; }
.rank-bg-2 { background: var(--muted-foreground) !important; }
.rank-bg-3, .rank-bg-4, .rank-bg-5 { background: var(--muted-foreground) !important; }

