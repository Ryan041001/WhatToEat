/* pages/spin/spin.wxss */
.spin-container {
  display: flex;
  flex-direction: column;
}

.unified-topbar {
  display: flex;
  align-items: center;
  padding: 12px 16px 16px 16px;
  background: linear-gradient(135deg, var(--primary), color-mix(in srgb, var(--primary) 60%, var(--warning)));
}

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.gap-2 { gap: 8px; }
.flex-1 { flex: 1; }
.px-4 { padding-left: 16px; padding-right: 16px; }
.pt-3 { padding-top: 12px; }
.pb-4 { padding-bottom: 16px; }
.pt-6 { padding-top: 24px; }
.mt-7 { margin-top: 28px; }
.mt-4 { margin-top: 16px; }
.mt-6 { margin-top: 24px; }
.py-16 { padding-top: 64px; padding-bottom: 64px; }
.py-4 { padding-top: 16px; padding-bottom: 16px; }
.px-12 { padding-left: 48px; padding-right: 48px; }
.p-5 { padding: 20px; }
.mx-4 { margin-left: 16px; margin-right: 16px; }
.rounded-full { border-radius: 9999px; }
.rounded-3xl { border-radius: 24px; }
.rounded-2xl { border-radius: 16px; }

.pointer-indicator {
  width: 0;
  height: 0;
  border-left: 12px solid transparent;
  border-right: 12px solid transparent;
  border-top: 24px solid var(--primary);
  z-index: 10;
  filter: drop-shadow(0 3px 6px color-mix(in srgb, var(--primary) 45%, transparent));
  margin-bottom: 2px;
}

.canvas-wrapper {
  border-radius: 50%;
  box-shadow: var(--neumorph-shadow-strong);
  overflow: hidden;
  background: var(--glass-surface-strong);
  border: 1px solid var(--glass-border-medium);
  margin-top: 2px;
}

.spin-canvas {
  width: 580rpx;
  height: 580rpx;
}

.spin-btn {
  background: linear-gradient(135deg, var(--primary), color-mix(in srgb, var(--primary) 60%, var(--warning)));
  color: var(--primary-foreground);
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: var(--glass-shadow-glow);
  border: 1px solid var(--glass-border-medium);
  transition: all 0.3s ease;
}

.spin-btn.is-spinning {
  background: linear-gradient(135deg, color-mix(in srgb, var(--muted-foreground) 35%, white), var(--muted-foreground));
  box-shadow: none;
  opacity: 0.8;
}

.spin-btn:active, .glass-chip:active {
  transform: scale(0.93);
}

.result-banner {
  background: linear-gradient(135deg, var(--primary), color-mix(in srgb, var(--primary) 60%, var(--color-warning)));
  box-shadow: var(--glass-shadow-glow);
}

.fade-in-up {
  animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes fadeInUp {
  0% {
    opacity: 0;
    transform: translateY(40px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
