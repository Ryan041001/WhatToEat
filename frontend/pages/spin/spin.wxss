/* pages/spin/spin.wxss */

.container {
  min-height: 100vh;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  padding: 32rpx 40rpx 44rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.2);
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.blob-1 {
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
}

.blob-2 {
  left: 128rpx;
  bottom: -64rpx;
  width: 168rpx;
  height: 168rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.hero-title {
  display: block;
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-badge {
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1px solid rgba(255, 255, 255, 0.32);
}

.hero-badge-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.hero-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.24);
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.25);
}

.hero-card-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.hero-card-title {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.hero-card-tip {
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  line-height: 1.5;
}

.content {
  margin-top: -10rpx;
}

.wheel-panel {
  margin: 0 48rpx 24rpx;
  padding: 32rpx;
  border-radius: 48rpx;
}

.wheel-panel-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.wheel-panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C5C5C;
}

.wheel-panel-tip {
  font-size: 22rpx;
  color: #999999;
  text-align: right;
}

.wheel-stage {
  position: relative;
  width: 100%;
  max-width: 590rpx;
  height: 590rpx;
  margin: 0 auto;
}

.wheel-base {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 36%, #FFF9F1 0%, #FFE9D1 62%, #FFD39C 100%);
  box-shadow: 0 22rpx 64rpx rgba(255, 158, 42, 0.18);
}

.wheel-canvas {
  position: relative;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 240ms ease;
}

.wheel-canvas.show {
  opacity: 1;
}

.wheel-loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wheel-loading-text {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #B98A5B;
  font-size: 24rpx;
}

.wheel-pointer {
  position: absolute;
  top: -18rpx;
  left: 50%;
  width: 58rpx;
  height: 58rpx;
  transform: translateX(-50%);
  color: #FF6B6B;
  z-index: 2;
  filter: drop-shadow(0 8rpx 16rpx rgba(255, 107, 107, 0.28));
}

.result-card {
  margin: 0 48rpx;
  max-height: 0;
  padding: 0 32rpx;
  opacity: 0;
  overflow: hidden;
  transform: translateY(18rpx);
  pointer-events: none;
  border-color: transparent;
  box-shadow: none;
  transition: max-height 240ms ease, opacity 220ms ease, transform 220ms ease, margin 220ms ease, padding 220ms ease;
}

.result-card.show {
  margin: 24rpx 48rpx 0;
  max-height: 820rpx;
  padding: 30rpx 32rpx;
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
  border-radius: 48rpx;
  border-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 107, 0.12);
}

.result-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.result-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  color: #FF8E53;
  background: rgba(255, 142, 83, 0.12);
}

.result-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.result-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.result-name {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.result-full-name {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

.result-chip {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1px solid currentColor;
  background: rgba(255, 255, 255, 0.56);
}

.result-chip-text {
  font-size: 20rpx;
  font-weight: 600;
  color: inherit;
}

.result-info {
  display: flex;
  gap: 22rpx;
  margin-top: 24rpx;
}

.result-image {
  width: 168rpx;
  height: 168rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
}

.result-body {
  flex: 1;
  min-width: 0;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.result-category {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  font-size: 22rpx;
  font-weight: 600;
}

.result-distance {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #999999;
}

.result-distance-icon {
  width: 24rpx;
  height: 24rpx;
  color: inherit;
}

.result-distance-text {
  color: inherit;
  font-size: 22rpx;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.result-tags .tag {
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 107, 107, 0.08);
  color: #FF6B6B;
  font-size: 20rpx;
  font-weight: 500;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 48rpx;
}

.spin-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 32rpx;
  border-radius: 48rpx;
  border: none;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  box-shadow: 0 16rpx 40rpx rgba(255, 107, 107, 0.25);
}

.spin-btn::after,
.action-ghost::after {
  border: none;
}

.spin-btn.spinning {
  background: #E9D6C1;
  box-shadow: 0 8rpx 20rpx rgba(154, 107, 58, 0.16);
}

.spin-btn.again {
  background: linear-gradient(135deg, #FF8E53 0%, #FFC857 100%);
}

.spin-btn[disabled] {
  opacity: 1;
}

.spin-btn-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
}

.spin-btn.spinning .spin-btn-text {
  color: #8A5423;
}

.action-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.68);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.08);
}

.action-ghost-text {
  color: #5C5C5C;
  font-size: 24rpx;
  font-weight: 600;
}

.empty-state {
  margin: 40rpx 48rpx 0;
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border-radius: 48rpx;
}

.empty-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  color: #C0B6AA;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #5C5C5C;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: #999999;
}
