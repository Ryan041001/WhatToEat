<!--pages/swipe/swipe.wxml-->
<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="header-title">💘 卡片滑选</text>
    <text class="header-subtitle">右滑喜欢 · 左滑不喜欢</text>
  </view>

  <!-- Card Stack -->
  <view class="card-stack" wx:if="{{restaurants.length > 0 && !showResult}}">
    <!-- Background cards -->
    <view 
      class="swipe-card card-{{index}}"
      wx:for="{{visibleCards}}"
      wx:key="id"
      style="{{item.style}}"
    >
      <image class="card-bg" src="{{item.image}}" mode="aspectFill"></image>
      <view class="card-overlay"></view>
      <view class="card-content">
        <text class="card-name">{{item.name}}</text>
        <view class="card-info">
          <text class="card-category">{{item.category}}</text>
          <text class="card-distance">📍 {{item.distance}}</text>
        </view>
        <view class="card-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{tagIndex < 4}}" wx:for-index="tagIndex">{{tag}}</text>
        </view>
      </view>

      <!-- Pass/Yep labels -->
      <view class="label label-pass" wx:if="{{index === 0 && swipeDirection === 'left'}}">
        <text class="label-text">PASS</text>
      </view>
      <view class="label label-yep" wx:if="{{index === 0 && swipeDirection === 'right'}}">
        <text class="label-text">YEP</text>
      </view>
    </view>

    <!-- Touch area for top card -->
    <view 
      class="touch-area"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></view>
  </view>

  <!-- Action Buttons -->
  <view class="action-buttons" wx:if="{{restaurants.length > 0 && !showResult}}">
    <button class="action-btn btn-pass" bindtap="handlePass">
      <text class="btn-icon">✗</text>
    </button>
    <button class="action-btn btn-like" bindtap="handleLike">
      <text class="btn-icon">♥</text>
    </button>
  </view>

  <!-- Progress -->
  <view class="progress" wx:if="{{restaurants.length > 0 && !showResult}}">
    <text class="progress-text">{{currentIndex + 1}} / {{restaurants.length}}</text>
  </view>

  <!-- Result -->
  <view class="result-view" wx:if="{{showResult}}">
    <text class="result-emoji">🎉</text>
    <text class="result-title">滑选完成！</text>
    <view class="result-card" wx:if="{{finalResult}}">
      <image class="result-image" src="{{finalResult.image}}" mode="aspectFill"></image>
      <text class="result-name">{{finalResult.name}}</text>
      <text class="result-subtitle">根据你的喜好，推荐这家~</text>
      <view class="result-meta">
        <text class="meta-item">{{finalResult.category}}</text>
        <text class="meta-item">📍 {{finalResult.distance}}</text>
        <text class="meta-item">⭐ {{finalResult.rating}}</text>
      </view>
    </view>
    <view class="result-empty" wx:else>
      <text class="empty-text">😅</text>
      <text class="empty-label">你一个都没选...</text>
      <text class="empty-tip">要不再试试？</text>
    </view>
    <button class="result-btn" bindtap="reset">
      <text>再玩一次</text>
    </button>
  </view>

  <!-- Empty State -->
  <view class="empty-state" wx:if="{{restaurants.length === 0}}">
    <text class="empty-emoji">😕</text>
    <text class="empty-text">还没有可选餐厅</text>
    <text class="empty-tip">快去添加一些餐厅吧~</text>
  </view>
</view>
