/* pages/swipe/swipe.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #FFF0ED 0%, #F8F7F4 100%);
}

/* Header */
.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* Card Stack */
.card-stack {
  position: relative;
  width: 100%;
  height: 600rpx;
  margin-bottom: 48rpx;
}

.swipe-card {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.card-0 {
  z-index: 3;
  transform: scale(1) translateY(0);
}

.card-1 {
  z-index: 2;
  transform: scale(0.95) translateY(10rpx);
  opacity: 0.8;
}

.card-2 {
  z-index: 1;
  transform: scale(0.9) translateY(20rpx);
  opacity: 0.5;
}

.card-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.7) 100%);
}

.card-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 48rpx 32rpx;
  z-index: 1;
}

.card-name {
  display: block;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.card-category {
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
}

.card-distance {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-tags .tag {
  padding: 4rpx 12rpx;
  background: rgba(249, 115, 22, 0.9);
  color: #fff;
  font-size: 20rpx;
  border-radius: 12rpx;
}

/* Labels */
.label {
  position: absolute;
  top: 80rpx;
  padding: 16rpx 48rpx;
  border-radius: 16rpx;
  border: 6rpx solid;
  z-index: 2;
  transform: rotate(-20deg);
}

.label-pass {
  left: 40rpx;
  border-color: #E63946;
}

.label-yep {
  right: 40rpx;
  border-color: #84A98C;
  transform: rotate(20deg);
}

.label-text {
  font-size: 48rpx;
  font-weight: 700;
}

.label-pass .label-text {
  color: #E63946;
}

.label-yep .label-text {
  color: #84A98C;
}

.touch-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-pass {
  background: #fff;
  border: 4rpx solid #E63946;
}

.btn-pass .btn-icon {
  color: #E63946;
  font-size: 56rpx;
  font-weight: 700;
}

.btn-like {
  background: #84A98C;
}

.btn-like .btn-icon {
  color: #fff;
  font-size: 56rpx;
}

/* Progress */
.progress {
  text-align: center;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

/* Result View */
.result-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  width: 100%;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5C5C5C;
  margin-bottom: 48rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 48rpx;
  background: #fff;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 32rpx;
}

.result-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.result-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #F97316;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.result-meta {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.meta-item {
  padding: 8rpx 20rpx;
  background: #F8F7F4;
  color: #5C5C5C;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.result-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-text {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.result-btn {
  width: 100%;
  padding: 32rpx;
  background: #F97316;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
}

.result-btn::after {
  border: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-state .empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.empty-state .empty-tip {
  font-size: 24rpx;
  color: #999;
}
