.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
}
.logo-placeholder {
  font-size: 160rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 80rpx;
  color: #333;
}
.btn-login {
  width: 80%;
  margin-bottom: 30rpx;
  background-color: #ff5722 !important;
}
.tips {
  font-size: 24rpx;
  color: #999;
}
