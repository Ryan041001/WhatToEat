/* pages/restaurants/restaurants.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: transparent;
  overflow: visible;
}

.error-banner,
.restaurants-hero,
.filters-shell {
  flex-shrink: 0;
}

.error-banner {
  margin: 20rpx 32rpx;
  background: #FFF0EF;
  color: #B42318;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.restaurants-hero {
  margin-bottom: 0;
}

.hero-shell {
  overflow: hidden;
  max-height: 520rpx;
  margin-bottom: 24rpx;
  opacity: 1;
  transition: max-height 0.28s ease, margin 0.28s ease, opacity 0.24s ease;
}

.hero-shell.collapsed {
  max-height: 0;
  margin-bottom: 0;
  opacity: 0;
}

.hero-blob-one {
  top: -40rpx;
  right: -36rpx;
  width: 220rpx;
  height: 220rpx;
}

.hero-blob-two {
  bottom: -78rpx;
  left: 120rpx;
  width: 172rpx;
  height: 172rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-eyebrow {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #FFFFFF;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

.hero-chip {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.hero-chip-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-surface {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-surface-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 24rpx;
}

.hero-surface-copy {
  display: flex;
  flex-direction: column;
}

.hero-surface-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.hero-surface-text {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

.filters-shell {
  position: relative;
  z-index: 20;
  margin-bottom: 24rpx;
}

.filters {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 26rpx 24rpx 24rpx;
}

.filters-heading {
  margin-bottom: 18rpx;
}

.filters-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #374151;
}

.filters-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8B93A6;
}

.category-scroll {
  white-space: nowrap;
  padding: 8rpx 0 20rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #6B7280;
  font-size: 24rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
  white-space: nowrap;
  flex-shrink: 0;
  box-shadow: inset 0 2rpx 10rpx rgba(255, 255, 255, 0.35);
}

.category-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9E2A 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 10rpx 28rpx rgba(255, 107, 107, 0.18);
}

.filter-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.filter-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #6B7280;
  font-size: 22rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
}

.filter-btn.active {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  border-color: rgba(255, 107, 107, 0.22);
  font-weight: 600;
}

.sort-wrap {
  position: relative;
  flex-shrink: 0;
}

.sort-dropdown {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.8);
}

.sort-text {
  font-size: 22rpx;
  color: #4B5563;
  font-weight: 600;
}

.sort-arrow {
  width: 24rpx;
  height: 24rpx;
  color: #8B93A6;
  transition: transform 0.2s ease;
}

.sort-arrow.open {
  transform: rotate(180deg);
}

.sort-menu {
  position: absolute;
  top: calc(100% + 14rpx);
  right: 0;
  width: 216rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-radius: 24rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.14);
  border: 1px solid rgba(255, 255, 255, 0.9);
  overflow: hidden;
  z-index: 30;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  border-bottom: 1px solid rgba(229, 231, 235, 0.7);
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active {
  background: rgba(255, 107, 107, 0.08);
}

.sort-label {
  font-size: 26rpx;
  color: #4B5563;
}

.sort-option.active .sort-label {
  color: #FF6B6B;
  font-weight: 600;
}

.sort-check {
  width: 28rpx;
  height: 28rpx;
  color: #FF6B6B;
}

.restaurant-list {
  flex: none;
  min-height: auto;
}

.list-content {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.list-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #374151;
}

.list-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8B93A6;
}

.restaurant-card {
  position: relative;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.restaurant-card.blacklisted {
  opacity: 0.74;
}

.card-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.card-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #374151;
}

.card-rating {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  background: rgba(255, 158, 42, 0.12);
  border-radius: 999rpx;
}

.star-shell {
  width: 28rpx;
  height: 28rpx;
  display: block;
  color: #FF9E2A;
}

.rating-value {
  font-size: 22rpx;
  color: #FF9E2A;
  font-weight: 700;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-chip {
  font-size: 20rpx;
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.meta-item {
  font-size: 22rpx;
  color: #667085;
}

.meta-dot {
  font-size: 20rpx;
  color: #D0D5DD;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 6rpx 14rpx;
  background: rgba(255, 158, 42, 0.12);
  color: #C56A12;
  font-size: 18rpx;
  border-radius: 14rpx;
}

.card-desc {
  font-size: 21rpx;
  color: #8B93A6;
  line-height: 1.7;
  letter-spacing: 0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: auto;
}

.action-btn {
  min-width: 124rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-block {
  background: rgba(255, 107, 107, 0.12);
  color: #FF6B6B;
}

.btn-detail {
  background: rgba(255, 158, 42, 0.14);
  color: #C56A12;
}

.btn-unblock {
  background: rgba(100, 116, 139, 0.12);
  color: #64748B;
}

.blacklist-overlay {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  background: rgba(71, 85, 105, 0.72);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  pointer-events: none;
}

.overlay-icon-shell {
  width: 34rpx;
  height: 34rpx;
  color: #FFFFFF;
}

.overlay-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon-shell {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 20rpx;
  color: #C28B78;
  opacity: 0.82;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #4B5563;
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8B93A6;
}
