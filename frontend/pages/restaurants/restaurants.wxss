/* pages/restaurants/restaurants.wxss */
.container-restaurant {
  width: 100vw;
  height: 100vh;
  background: var(--background);
  overflow: hidden;
}

.header-bg {
  background: linear-gradient(135deg, var(--primary), #ff9a5c);
  padding: 24rpx 32rpx 32rpx;
  flex-shrink: 0;
}

.mt-status {
  padding-top: var(--status-bar-height, 0); 
  /* Mini program automatically handles this if nav is default, 
     but if custom nav, we need it. We will assume default but adjust spacing slightly. */
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
}

.header-badge-active {
  background: rgba(255, 255, 255, 0.2);
  color: var(--primary-foreground);
  font-size: 22rpx;
}

.header-badge-black {
  background: rgba(0, 0, 0, 0.2);
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.search-bar {
  background: rgba(255, 255, 255, 0.94);
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 26rpx;
  color: var(--foreground);
}

.search-placeholder {
  color: var(--muted-foreground);
}

.border-b {
  border-bottom: 1px solid var(--glass-border-soft);
  background: var(--primary-foreground);
}

.cat-list {
  width: 100%;
  white-space: nowrap;
  flex-shrink: 0;
}

.w-max {
  width: max-content;
}

.cat-chip {
  flex-shrink: 0;
  transition: all 0.2s;
}

.cat-active {
  background: var(--primary) !important;
  color: var(--primary-foreground) !important;
  font-weight: 600;
  font-size: 24rpx;
}

.cat-inactive {
  background: var(--glass-surface-medium) !important;
  color: var(--muted-foreground) !important;
  font-weight: 400;
  font-size: 24rpx;
}

.filter-row {
  flex-shrink: 0;
}

.price-chip {
  font-size: 22rpx;
}

.price-active {
  background: var(--glass-surface-light) !important;
  color: var(--primary) !important;
  font-weight: 600;
}

.price-inactive {
  background: var(--glass-surface-medium) !important;
  color: var(--muted-foreground) !important;
  font-weight: 400;
}

.list-container {
  flex: 1;
  height: 0; /* needed for scroll-view inside flex column */
}

.restaurant-card {
  box-shadow: var(--neumorph-shadow-strong);
  background: var(--glass-surface-medium);
}

.card-blacklisted {
  background: var(--glass-surface-light);
  opacity: 0.75;
}

.card-normal {
  background: var(--glass-surface-medium);
}

.card-img {
  width: 100%;
  height: 320rpx;
  display: block;
}

.absolute-overlay {
  position: absolute;
  inset: 0;
  background: rgba(59, 38, 23, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-tl {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: var(--glass-surface-strong) !important;
  border: 1px solid var(--glass-border-medium) !important;
  border-radius: 24rpx !important;
  padding: 8rpx 20rpx !important;
}

.chip-tr {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--glass-surface-strong) !important;
  border: 1px solid var(--glass-border-medium) !important;
  border-radius: 24rpx !important;
  padding: 8rpx 20rpx !important;
}

.chip-br {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: var(--glass-surface-strong) !important;
  border: 1px solid var(--glass-border-medium) !important;
  border-radius: 50% !important;
  width: 72rpx;
  height: 72rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.chevron {
  transition: transform 0.3s;
}

.chevron-up {
  transform: rotate(180deg);
}

.card-content {
  background: var(--glass-surface-light);
  border-top: 1px solid var(--glass-border-soft);
}

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.truncate-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tag-chip {
  font-size: 20rpx;
  color: var(--warning) !important;
  background: rgba(255,255,255, 0.86) !important;
  border-radius: 8rpx !important;
  padding: 2rpx 12rpx !important;
  border: none !important;
}

.action-row {
  border-top: 1px solid var(--glass-border-soft);
}

.action-btn {
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.9);
}

.toggle-bl-btn {
  transition: transform 0.2s;
}

.toggle-bl-btn:active {
  transform: scale(0.95);
}

.expanded-actions {
  border-top: 1px dashed var(--glass-border-soft);
  overflow: hidden;
}

.btn-del {
  background: var(--glass-surface-light);
  color: var(--primary);
}

.anim-expand {
  animation: expandDown 0.3s ease-out forwards;
}

@keyframes expandDown {
  from { opacity: 0; max-height: 0; }
  to { opacity: 1; max-height: 100rpx; }
}

.py-0-5 {
  padding-top: 4rpx;
  padding-bottom: 4rpx;
}

.load-more-wrap {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
}

.load-more-btn {
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary-foreground);
  background: var(--primary);
  box-shadow: var(--glass-shadow-ambient);
}

.load-more-tip {
  font-size: 22rpx;
  color: var(--muted-foreground);
}
