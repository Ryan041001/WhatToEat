/* pages/restaurants/restaurants.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8F7F4;
}

.error-banner {
  margin: 20rpx 32rpx;
  background: #fff0ef;
  color: #b42318;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

/* Filters */
.filters {
  background: #fff;
  padding-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-scroll {
  white-space: nowrap;
  padding: 16rpx 0;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #E8E8E8;
  color: #5C5C5C;
  font-size: 24rpx;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.category-item.active {
  background: #F97316;
  color: #fff;
  font-weight: 600;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.filter-group {
  display: flex;
  gap: 12rpx;
}

.filter-btn {
  padding: 8rpx 20rpx;
  background: #E8E8E8;
  color: #5C5C5C;
  font-size: 22rpx;
  border-radius: 32rpx;
}

.filter-btn.active {
  background: #FFF0ED;
  color: #F97316;
  border: 1px solid #F97316;
  font-weight: 600;
}

.sort-dropdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: #E8E8E8;
  border-radius: 32rpx;
}

.sort-text {
  font-size: 22rpx;
  color: #5C5C5C;
}

.sort-arrow {
  font-size: 16rpx;
  color: #999;
}

/* Restaurant List */
.restaurant-list {
  flex: 1;
  padding: 16rpx 0;
}

.list-content {
  padding: 0 32rpx 32rpx;
}

.restaurant-card {
  position: relative;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.restaurant-card.blacklisted {
  opacity: 0.6;
}

.card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.card-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #5C5C5C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.star {
  font-size: 20rpx;
}

.rating-value {
  font-size: 22rpx;
  color: #F97316;
  font-weight: 600;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.meta-divider {
  font-size: 22rpx;
  color: #ccc;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag {
  padding: 2rpx 12rpx;
  background: #FFF0ED;
  color: #F97316;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-action {
  display: flex;
  align-items: center;
}

.action-btn {
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-block {
  background: #FFE4CC;
  color: #F97316;
}

.btn-unblock {
  background: #E8E8E8;
  color: #5C5C5C;
}

.blacklist-overlay {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: rgba(92, 92, 92, 0.7);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.overlay-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

/* Sort Modal */
.sort-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.sort-modal.show {
  opacity: 1;
  pointer-events: all;
}

.sort-content {
  width: 100%;
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 32rpx;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.sort-modal.show .sort-content {
  transform: translateY(0);
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1px solid #E8E8E8;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active {
  background: #FFF8F0;
}

.sort-label {
  font-size: 28rpx;
  color: #5C5C5C;
}

.sort-option.active .sort-label {
  color: #F97316;
  font-weight: 600;
}

.sort-check {
  font-size: 32rpx;
  color: #F97316;
  font-weight: 700;
}
