.detail-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.detail-back-btn {
  position: fixed;
  top: 24rpx;
  left: 24rpx;
  z-index: 200;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
}
.cover-img {
  width: 100%;
  height: 480rpx;
  background-color: #eee;
  display: block;
}
.info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
.price {
  font-size: 28rpx;
  color: #ff5722;
}
.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.rating {
  font-size: 28rpx;
  color: #ff9800;
  margin-right: 20rpx;
}
.tags {
  display: flex;
}
.tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}
.address-row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}
.address-icon {
  margin-right: 10rpx;
}
.address-text {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.arrow {
  color: #ccc;
  margin-left: 10rpx;
}
.section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}
.dishes-scroll {
  display: flex;
  height: 240rpx;
}
.dish-item {
  width: 180rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.dish-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: #ddd;
  margin-bottom: 10rpx;
}
.dish-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
  z-index: 100;
}
.btn-primary {
  width: 100% !important;
  background-color: #ff5722 !important;
  color: #fff;
}
