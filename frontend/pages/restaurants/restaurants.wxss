/* pages/restaurants/restaurants.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8F7F4;
}

.error-banner {
  margin: 20rpx 32rpx;
  background: #fff0ef;
  color: #b42318;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

/* Filters */
.filters {
  background: #fff;
  padding-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-scroll {
  white-space: nowrap;
  padding: 16rpx 0;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #E8E8E8;
  color: #5C5C5C;
  font-size: 24rpx;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.category-item.active {
  background: #F97316;
  color: #fff;
  font-weight: 600;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.filter-group {
  display: flex;
  gap: 12rpx;
}

.filter-btn {
  padding: 8rpx 20rpx;
  background: #E8E8E8;
  color: #5C5C5C;
  font-size: 22rpx;
  border-radius: 32rpx;
}

.filter-btn.active {
  background: #FFF0ED;
  color: #F97316;
  border: 1px solid #F97316;
  font-weight: 600;
}

.sort-dropdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: #E8E8E8;
  border-radius: 32rpx;
}

.sort-wrap {
  position: relative;
}

.sort-text {
  font-size: 22rpx;
  color: #5C5C5C;
}

.sort-arrow {
  font-size: 16rpx;
  color: #999;
  transition: transform 0.2s ease;
}

.sort-arrow.open {
  transform: rotate(180deg);
}

/* Restaurant List */
.restaurant-list {
  flex: 1;
  padding: 16rpx 0;
}

.list-content {
  padding: 0 32rpx 32rpx;
}

.restaurant-card {
  position: relative;
  display: flex;
  gap: 28rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.restaurant-card.blacklisted {
  opacity: 0.6;
}

.card-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-right: 4rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 2rpx;
}

.card-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #3F3F46;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  background: #FFF5E9;
  border-radius: 999rpx;
}

.star {
  font-size: 20rpx;
}

.rating-value {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: -2rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #6B7280;
}

.meta-chip {
  font-size: 20rpx;
  color: #78716C;
  background: #F5F5F4;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.meta-dot {
  font-size: 20rpx;
  color: #C4C4C4;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: -4rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: #FFF0ED;
  color: #F97316;
  font-size: 19rpx;
  border-radius: 12rpx;
}

.card-desc {
  font-size: 21rpx;
  color: #8C8C8C;
  line-height: 1.7;
  letter-spacing: 0.4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 2rpx;
}

.action-btn {
  min-width: 114rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-block {
  background: #FFE9D2;
  color: #EA6E13;
}

.btn-unblock {
  background: #ECECEC;
  color: #666;
}

.blacklist-overlay {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: rgba(92, 92, 92, 0.7);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.overlay-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C5C5C;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

.sort-menu {
  position: absolute;
  top: calc(100% + 10rpx);
  right: 0;
  width: 200rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.14);
  border: 1px solid #f1f1f1;
  overflow: hidden;
  z-index: 30;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  border-bottom: 1px solid #E8E8E8;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active {
  background: #FFF8F0;
}

.sort-label {
  font-size: 28rpx;
  color: #5C5C5C;
}

.sort-option.active .sort-label {
  color: #F97316;
  font-weight: 600;
}

.sort-check {
  font-size: 32rpx;
  color: #F97316;
  font-weight: 700;
}
