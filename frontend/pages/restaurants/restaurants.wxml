<view class="detail-container">
  <view class="detail-back-btn" bindtap="handleBack">← 返回</view>
  <loading-spinner show="{{isLoading}}" message="加载中..."></loading-spinner>
  
  <block wx:if="{{!isLoading && restaurant}}">
    <image class="cover-img" src="{{restaurant.cover || '/assets/restaurant-2.svg'}}" mode="aspectFill"></image>
    
    <view class="info-section">
      <view class="title-row">
        <text class="name">{{restaurant.name}}</text>
        <text class="price">￥{{restaurant.avgPrice}}/人</text>
      </view>
      
      <view class="meta-row">
        <text class="rating">⭐ {{restaurant.rating}}</text>
        <view class="tags">
          <text class="tag" wx:for="{{restaurant.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      
      <view class="address-row" bindtap="handleOpenLocation">
        <text class="address-icon">📍</text>
        <text class="address-text">{{restaurant.address || '杭州市西湖区教工路149号'}}</text>
        <text class="arrow">></text>
      </view>
    </view>
    
    <view class="section">
      <view class="section-title">推荐菜品</view>
      <scroll-view class="dishes-scroll" scroll-x enable-flex>
        <view class="dish-item" wx:for="{{restaurant.dishes}}" wx:key="name">
          <image class="dish-img" src="{{item.image}}"></image>
          <view class="dish-name">{{item.name}}</view>
        </view>
      </scroll-view>
    </view>
    
    <view class="bottom-action">
      <button class="btn-primary" type="primary" bindtap="handleGoThere">就去这吃！</button>
    </view>
  </block>
</view>
