<view class="mine-container">
  <view class="header">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/restaurant-8.svg'}}" mode="aspectFill"></image>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickName || '未登录用户'}}</view>
      <view class="desc">吃货等级：Lv.1</view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="handleMenuClick" data-type="history">
      <text class="menu-title">浏览历史</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleMenuClick" data-type="favorites">
      <text class="menu-title">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="handleMenuClick" data-type="settings">
      <text class="menu-title">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <button class="logout-btn" type="warn" bindtap="handleLogout">退出登录</button>
</view>
