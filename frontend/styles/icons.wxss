.svg-icon,
.app-icon {
  display: block;
  width: 100%;
  height: 100%;
  flex-shrink: 0;
  vertical-align: middle;
  color: inherit;
  background-color: currentColor;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-size: contain;
  mask-size: contain;
}

.icon-fill {
  width: 100%;
  height: 100%;
}

.icon-xs {
  width: 24rpx;
  height: 24rpx;
}

.icon-sm {
  width: 28rpx;
  height: 28rpx;
}

.icon-md {
  width: 32rpx;
  height: 32rpx;
}

.icon-lg {
  width: 40rpx;
  height: 40rpx;
}

.icon-xl {
  width: 48rpx;
  height: 48rpx;
}

.icon-2xl {
  width: 64rpx;
  height: 64rpx;
}

.icon-3xl {
  width: 96rpx;
  height: 96rpx;
}

.icon-spin {
  animation: app-icon-spin 1s linear infinite;
}

@keyframes app-icon-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

