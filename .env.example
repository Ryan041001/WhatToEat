# Docker Compose local development defaults
# DevTools can use http://127.0.0.1:${BACKEND_PORT}
# Real-device testing should use http://<your-host-lan-ip>:${BACKEND_PORT}

BACKEND_PORT=8080
MYSQL_PORT=3306
DB_NAME=whattoeat_dev
DB_USER=whattoeat
DB_PASSWORD=whattoeat
DB_ROOT_PASSWORD=root

# Spring Boot (dev profile)
DB_URL=jdbc:mysql://localhost:3306/whattoeat_dev?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
DB_USERNAME=whattoeat

AMAP_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=5

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AUTH_BASE_URL=https://api.weixin.qq.com
WECHAT_MOCK_LOGIN_ENABLED=true

AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_SECONDS=5

# Note: Restaurant search and recommendation endpoints require a real Amap key.
